{
  "name": "factus-js",
  "type": "module",
  "version": "2.0.0",
  "description": "TypeScript SDK for the Factus Colombian e-invoicing API",
  "author": "sbetav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbetav/factus-js.git",
    "directory": "packages/factus-js"
  },
  "bugs": {
    "url": "https://github.com/sbetav/factus-js/issues"
  },
  "homepage": "https://factusjs.vercel.app",
  "keywords": [
    "factus",
    "factus-api",
    "colombia",
    "dian",
    "electronic-invoicing",
    "e-invoicing",
    "facturacion-electronica",
    "factura-electronica",
    "invoicing",
    "billing",
    "api",
    "sdk",
    "typescript",
    "javascript",
    "nodejs"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:types",
    "test:unit": "vitest run src/__tests__/unit",
    "test:watch": "vitest src/__tests__/unit",
    "test:sandbox": "vitest run src/__tests__/sandbox",
    "test:all": "vitest run src/__tests__",
    "test:types": "vitest run src/__tests__/unit/constants.test-d.ts src/__tests__/unit/public-types.test-d.ts --typecheck",
    "test:coverage": "vitest run src/__tests__/unit --coverage"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsdown": "^0.21.3",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
