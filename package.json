{
  "name": "factus-js",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "sync-factus-docs": "node ./scripts/sync-factus-docs.mjs",
    "release": "pnpm --filter factus-js build && changeset publish",
    "release:factus-js": "pnpm --filter factus-js publish --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cheerio": "1.0.0-rc.12",
    "enquirer": "^2.4.1",
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=18"
  }
}
