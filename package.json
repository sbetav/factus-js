{
  "name": "factus-js",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "release": "pnpm --filter factus-js build && changeset publish",
    "release:factus-js": "pnpm --filter factus-js publish --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}